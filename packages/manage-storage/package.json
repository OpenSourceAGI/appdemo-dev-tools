{
  "name": "manage-storage",
  "version": "0.0.2",
  "description": "Storage manager supporting AWS S3, Cloudflare R2, and Backblaze B2 with automatic provider detection",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "keywords": [
    "s3",
    "r2",
    "cloudflare",
    "backblaze",
    "b2",
    "storage",
    "cloud",
    "aws",
    "object-storage",
    "multi-cloud"
  ],
  "author": "vtempest",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/vtempest/Starter-DOCS.git",
    "directory": "storage"
  },
  "bugs": {
    "url": "https://github.com/vtempest/Starter-DOCS/issues"
  },
  "homepage": "https://github.com/vtempest/Starter-DOCS#readme",
  "dependencies": {
    "@aws-lite/client": "^0.23.2",
    "@aws-lite/s3": "^0.2.6",
    "dotenv": "^17.2.3"
  },
  "devDependencies": {
    "@aws-lite/s3-types": "^0.2.6",
    "@types/node": "^22.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.3.0"
  },
  "scripts": {
    "build": "vite build",
    "prepublishOnly": "npm run build",
    "ship": "npx standard-version --release-as patch; rm CHANGELOG.md; npm publish"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ]
}
